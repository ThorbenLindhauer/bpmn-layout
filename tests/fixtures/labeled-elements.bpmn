<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
             id="labeled-elements" targetNamespace="http://bpmn.io/schema/bpmn">
  <process id="process1" isExecutable="false">
    <startEvent id="start1" name="Order Received"/>
    <exclusiveGateway id="gw1" name="In Stock?"/>
    <task id="task1" name="Ship Order"/>
    <endEvent id="end1" name="Order Complete"/>
    <sequenceFlow id="sf1" sourceRef="start1" targetRef="gw1"/>
    <sequenceFlow id="sf2" sourceRef="gw1" targetRef="task1" name="Yes"/>
    <sequenceFlow id="sf3" sourceRef="task1" targetRef="end1"/>
  </process>
</definitions>
