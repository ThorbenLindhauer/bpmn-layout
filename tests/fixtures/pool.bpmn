<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
             id="pool-diagram" targetNamespace="http://bpmn.io/schema/bpmn">
  <collaboration id="collab1">
    <participant id="pool1" processRef="process1" name="Pool 1"/>
    <participant id="pool2" processRef="process2" name="Pool 2"/>
  </collaboration>
  <process id="process1" isExecutable="false">
    <startEvent id="start1"/>
    <task id="task1"/>
    <endEvent id="end1"/>
    <sequenceFlow id="sf1" sourceRef="start1" targetRef="task1"/>
    <sequenceFlow id="sf2" sourceRef="task1" targetRef="end1"/>
  </process>
  <process id="process2" isExecutable="false">
    <startEvent id="start2"/>
    <task id="task2"/>
    <endEvent id="end2"/>
    <sequenceFlow id="sf3" sourceRef="start2" targetRef="task2"/>
    <sequenceFlow id="sf4" sourceRef="task2" targetRef="end2"/>
  </process>
  <bpmndi:BPMNDiagram id="diagram1">
    <bpmndi:BPMNPlane id="plane1" bpmnElement="collab1"/>
  </bpmndi:BPMNDiagram>
</definitions>
